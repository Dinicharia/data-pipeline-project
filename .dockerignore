# .dockerignore
# Excluded from Docker build context

# Virtual environment — huge, not needed (container has its own Python)
venv/

# Raw data files — too large, regenerated by the pipeline
data/

# Log files — generated at runtime
logs/

# Airflow-specific files — not needed in the pipeline image
airflow/
docker-compose.airflow.yml
Dockerfile.airflow

# Git history — not needed in production
.git/
.gitignore

# Development files
*.pyc
__pycache__/
.pytest_cache/
*.egg-info/

# Secrets — never in Docker images
config/secrets.env
.env

# Documentation
*.md