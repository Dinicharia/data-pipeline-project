# config/secrets.env.example
# Copy this file to config/secrets.env and fill in real values.
# NEVER commit secrets.env — only this example file.

WEATHER_API_KEY=get_from_openweathermap_org
GITHUB_TOKEN=generate_at_github_settings_tokens
NASA_API_KEY=get_from_api_nasa_gov_or_use_DEMO_KEY

DB_HOST=localhost
DB_PORT=5432
DB_NAME=pipeline_db
DB_USER=pipeline_user
DB_PASSWORD=choose_a_strong_password

LOG_LEVEL=INFO
ENVIRONMENT=development